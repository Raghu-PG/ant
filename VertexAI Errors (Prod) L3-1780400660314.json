          "formatAs": "logs",
          "lsql": "kubernetes.container.name = \"ipa-api-server\"\nAND kubernetes.pod_labels.release = \"prod\"\n| parseJson(message)\n| cloud := splitString(field=request_url, by=\"\\\\/\", index=2)\n| cloud = \"vertexai\"\n| is_error := if(condition=regex(field=levelname, \"^ERROR$\"), then=1, else=0)\n| is_429 := if(condition=regex(field=message, \"429\"), then=1, else=0)\n| is_429_error := is_error * is_429\n| regex(field=request_url, \"\\/models\\/(?P<model>[^\\/]+)\")\n| groupby(model, function=[sum(is_429_error, as=error_count), count(field=request_id, as=total_calls, distinct=true)])\n| error_count > 0\n| error_percentage := (error_count / total_calls) * 100\n| sort(error_percentage, order=desc)\n| select([model, total_calls, error_count, error_percentage])",
          "queryType": "LQL",
          "refId": "A",
          "repository": "aks-aif-mt",
          "version": "1.7.6"
        }
