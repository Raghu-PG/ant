          max by (cluster, namespace, release, queue_name) (
            queue_dead_letter_approximate_count
          ) > 0
        for: 5m
        labels:
          severity: Warning
          alert_namespace: itsgenai
          alert_name: GenAI DLQ Non-Empty
          alert_owner: advanalyticsapps.im@pg.com
          name_space: itsgenai
          primary_property: fingerprint
          secondary_property: startsAt
          source_system: spyglass
          uc_environment: prod
          correlation_rule: alert_name
          email_subject: '[GenAI Queue] Messages in dead-letter queue ({{ $labels.queue_name }})'
        annotations:
          message: >-
            DLQ for queue {{ $labels.queue_name }}
            ({{ $labels.cluster }}/{{ $labels.namespace }}/{{ $labels.release }})
            holds {{ $value }} message(s). Any DLQ message means something broke.

      # --- DLQ Depth — Critical (> 100) -------------------------------------
      - alert: GenAI_DLQDepth_Critical
        expr: |
          max by (cluster, namespace, release, queue_name) (
            queue_dead_letter_approximate_count
          ) > 100
        for: 5m
        labels:
          severity: Critical
          alert_namespace: itsgenai
          alert_name: GenAI DLQ Mass Failure
          alert_owner: advanalyticsapps.im@pg.com
          name_space: itsgenai
          primary_property: fingerprint
          secondary_property: startsAt
          source_system: spyglass
          uc_environment: prod
          correlation_rule: alert_name
          application_name: GenAI
          conveyor_route: universal_connector
          actionability_type: 'incident,email'
          alert_actionable: 'true'
          cost_center: 8000501288
          lob: itsgenai
          snow_assignment_group: DevOps_AdvAnalytApps
          snow_business_service: c8554ce8371c62405979a9c2b3990ef7
          snow_category: 'Business Application & Databases'
          snow_component: Alerts
          snow_configuration_item: GenAI (Artificial Intelligence) Platform
          snow_contact_type: Auto Ticket
          snow_description: 'DLQ depth > 100 — mass failure. Bad deployment, schema change, or downstream outage. Dashboard: https://grafana.spyglass.pg.com/d/genai-queue-storage-consumption'
          snow_impact: '2'
          snow_is_cbp_impacted: 'No'
          snow_incident_type: 'Operations: Application Availability'
          snow_location: ALL LOCATIONS
          snow_service_offering: 28a5002c371c62405979a9c2b3990e21
          snow_short_description: 'GenAI DLQ Mass Failure — Depth > 100'
          snow_subcategory: Business Applications
          snow_urgency: '2'
          email_subject: '[GenAI Queue] CRITICAL: DLQ mass failure — depth > 100 ({{ $labels.queue_name }})'
        annotations:
          message: >-
            DLQ for queue {{ $labels.queue_name }}
            ({{ $labels.cluster }}/{{ $labels.namespace }}/{{ $labels.release }})
            holds {{ $value }} message(s). A spike this large indicates a systemic
            issue — bad deployment, schema change, or downstream outage.

