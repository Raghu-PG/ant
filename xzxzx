  # ---------------------------------------------------------------------------
  # ANOMALY DETECTION — z-score baseline (throughput drop)
  # ---------------------------------------------------------------------------
  - name: genai-queue-storage.anomaly.alerts
    rules:
      - alert: GenAI_QueueThroughputAnomaly_Warning
        expr: |
          (
            queue:processing_throughput:rate5m
            - avg_over_time(queue:processing_throughput:rate5m[6h])
          )
          / clamp_min(stddev_over_time(queue:processing_throughput:rate5m[6h]), 0.001) < -3
          and
          avg_over_time(queue:processing_throughput:rate5m[6h]) > 0.1
          and
          stddev_over_time(queue:processing_throughput:rate5m[6h]) > 0
        for: 10m
        labels:
          severity: Warning
          alert_namespace: itsgenai
          alert_name: GenAI Queue Throughput Anomalous Drop
          alert_owner: advanalyticsapps.im@pg.com
          name_space: itsgenai
          primary_property: fingerprint
          secondary_property: startsAt
          source_system: spyglass
          uc_environment: prod
          correlation_rule: alert_name
          email_subject: '[GenAI Queue] Throughput anomalously low vs baseline ({{ $labels.queue_name }})'
        annotations:
          message: >-
            Processing throughput for queue {{ $labels.queue_name }}
            ({{ $labels.cluster }}/{{ $labels.namespace }}/{{ $labels.release }})
            is more than 3 standard deviations below its trailing 6h mean. The queue
            is processing far slower than normal — early sign of degradation.

