# =============================================================================
# GenAI Platform — Queue Storage Consumption Monitoring Alerts
# Jira: GENAI-2580
# Dashboard: genai-queue-storage-consumption
#
# NOTES:
#   - Gauge metrics (depth, age, DLQ depth) use `max by (...)` because the
#     exporter emits one series PER POD. Using `sum` would multiply the real
#     queue depth by the number of consumer pods.
#   - Counter metrics (dequeued, uploaded, consumer_runs, dlq_messages) use
#     `sum by (...)` because each pod processes different messages additively.
#   - Grouping by (cluster, namespace, release, queue_name) ensures environments
#     never merge across the global Thanos view.
#   - 4 metrics referenced in the dashboard JSON do not exist yet:
#       queue_messages_sent_total, queue_messages_deleted_total,
#       queue_dead_letter_store_failures_total, queue_dead_letter_delete_failures_total
#     Alerts for these are commented out — enable when the app emits them.
# =============================================================================

groups:
  # ---------------------------------------------------------------------------
  # RECORDING RULES — baseline inputs for the anomaly alert
  # Uses histogram _count (completions regardless of success/failure) because
  # query confirmed queue_messages_uploaded_total only has status="failure",
  # no status="success" series exists.
  # ---------------------------------------------------------------------------
  - name: genai-queue-storage.recording.rules
    interval: 1m
    rules:
      - record: queue:processing_throughput:rate5m
        expr: |
          sum by (cluster, namespace, release, queue_name) (
            rate(queue_message_processing_duration_seconds_count[5m])
          )

      - record: queue:messages_dequeued:rate5m
        expr: |
          sum by (cluster, namespace, release, queue_name) (
            rate(queue_messages_dequeued_total[5m])
          )

  # ---------------------------------------------------------------------------
  # MAIN QUEUE ALERTS
  # ---------------------------------------------------------------------------
  - name: genai-queue-storage.main.alerts
    rules:

      # --- Oldest Message Age — Warning (> 10m) -------------------------------
      - alert: GenAI_QueueOldestMessageAge_Warning
        expr: |
          max by (cluster, namespace, release, queue_name) (
            queue_oldest_message_age_seconds
          ) > 600
        for: 5m
        labels:
          severity: Warning
          alert_namespace: itsgenai
          alert_name: GenAI Queue Oldest Message Age Warning
          alert_owner: advanalyticsapps.im@pg.com
          name_space: itsgenai
          primary_property: fingerprint
          secondary_property: startsAt
          source_system: spyglass
          uc_environment: prod
          correlation_rule: alert_name
          email_subject: '[GenAI Queue] Oldest message > 10m — {{ $labels.queue_name }} ({{ $labels.cluster }})'
        annotations:
          message: >-
            Oldest visible message in queue {{ $labels.queue_name }}
            ({{ $labels.cluster }}/{{ $labels.namespace }}/{{ $labels.release }})
            is {{ $value | humanizeDuration }} old. Normal processing should clear
            messages within ~4m (2 celery-beat cycles). 10m+ implies repeated failures.

      # --- Oldest Message Age — Critical (> 30m) -----------------------------
      - alert: GenAI_QueueOldestMessageAge_Critical
        expr: |
          max by (cluster, namespace, release, queue_name) (
            queue_oldest_message_age_seconds
          ) > 1800
        for: 5m
        labels:
          severity: Critical
          alert_namespace: itsgenai
          alert_name: GenAI Queue Oldest Message Age Critical
          alert_owner: advanalyticsapps.im@pg.com
          name_space: itsgenai
          primary_property: fingerprint
          secondary_property: startsAt
          source_system: spyglass
          uc_environment: prod
          correlation_rule: alert_name
          application_name: GenAI
          conveyor_route: universal_connector
          actionability_type: 'incident,email'
          alert_actionable: 'true'
          cost_center: 8000501288
          lob: itsgenai
          snow_assignment_group: DevOps_AdvAnalytApps
          snow_business_service: c8554ce8371c62405979a9c2b3990ef7
          snow_category: 'Business Application & Databases'
          snow_component: Alerts
          snow_configuration_item: GenAI (Artificial Intelligence) Platform
          snow_contact_type: Auto Ticket
          snow_description: 'Queue processing stalled — oldest message older than 30m. Consumer/celery beat may be dead. Dashboard: https://grafana.spyglass.pg.com/d/genai-queue-storage-consumption'
          snow_impact: '3'
          snow_is_cbp_impacted: 'No'
          snow_incident_type: 'Operations: Application Availability'
          snow_location: ALL LOCATIONS
          snow_service_offering: 28a5002c371c62405979a9c2b3990e21
          snow_short_description: 'GenAI Queue Processing Stalled — Oldest Message > 30m'
          snow_subcategory: Business Applications
          snow_urgency: '2'
          email_subject: '[GenAI Queue] CRITICAL: Processing stalled — oldest message > 30m ({{ $labels.queue_name }})'
        annotations:
          message: >-
            Oldest visible message in queue {{ $labels.queue_name }}
            ({{ $labels.cluster }}/{{ $labels.namespace }}/{{ $labels.release }})
            is {{ $value | humanizeDuration }} old. Processing is stalled — most likely
            the celery beat scheduler died. Check consumer pod liveness immediately.

      # --- Queue Depth — Warning (> 1000) ------------------------------------
      - alert: GenAI_QueueDepth_Warning
        expr: |
          max by (cluster, namespace, release, queue_name) (
            queue_approximate_message_count
          ) > 1000
        for: 10m
        labels:
          severity: Warning
          alert_namespace: itsgenai
          alert_name: GenAI Queue Depth Warning
          alert_owner: advanalyticsapps.im@pg.com
          name_space: itsgenai
          primary_property: fingerprint
          secondary_property: startsAt
          source_system: spyglass
          uc_environment: prod
          correlation_rule: alert_name
          email_subject: '[GenAI Queue] Backlog building — depth > 1000 ({{ $labels.queue_name }})'
        annotations:
          message: >-
            Queue {{ $labels.queue_name }}
            ({{ $labels.cluster }}/{{ $labels.namespace }}/{{ $labels.release }})
            has held {{ $value }} messages for 10m. Normal operation keeps depth near 0.

      # --- Queue Depth — Critical (> 5000) -----------------------------------
      - alert: GenAI_QueueDepth_Critical
        expr: |
          max by (cluster, namespace, release, queue_name) (
            queue_approximate_message_count
          ) > 5000
        for: 5m
        labels:
          severity: Critical
          alert_namespace: itsgenai
          alert_name: GenAI Queue Depth Critical
          alert_owner: advanalyticsapps.im@pg.com
          name_space: itsgenai
          primary_property: fingerprint
          secondary_property: startsAt
          source_system: spyglass
          uc_environment: prod
          correlation_rule: alert_name
          application_name: GenAI
          conveyor_route: universal_connector
          actionability_type: 'incident,email'
          alert_actionable: 'true'
          cost_center: 8000501288
          lob: itsgenai
          snow_assignment_group: DevOps_AdvAnalytApps
          snow_business_service: c8554ce8371c62405979a9c2b3990ef7
          snow_category: 'Business Application & Databases'
          snow_component: Alerts
          snow_configuration_item: GenAI (Artificial Intelligence) Platform
          snow_contact_type: Auto Ticket
          snow_description: 'Queue overloaded — depth > 5000. System cannot drain fast enough. Dashboard: https://grafana.spyglass.pg.com/d/genai-queue-storage-consumption'
          snow_impact: '3'
          snow_is_cbp_impacted: 'No'
          snow_incident_type: 'Operations: Application Availability'
          snow_location: ALL LOCATIONS
          snow_service_offering: 28a5002c371c62405979a9c2b3990e21
          snow_short_description: 'GenAI Queue Overloaded — Depth > 5000'
          snow_subcategory: Business Applications
          snow_urgency: '2'
          email_subject: '[GenAI Queue] CRITICAL: Queue overloaded — depth > 5000 ({{ $labels.queue_name }})'
        annotations:
          message: >-
            Queue {{ $labels.queue_name }}
            ({{ $labels.cluster }}/{{ $labels.namespace }}/{{ $labels.release }})
            depth is {{ $value }}. The system cannot drain the queue fast enough —
            investigate consumer throughput or scale out.

      # --- Consumer Task Stalled (no runs in 10m) ----------------------------
      - alert: GenAI_QueueConsumerTaskStalled_Critical
        expr: |
          sum by (cluster, namespace, release, queue_name) (
            increase(queue_consumer_runs_total[10m])
          ) == 0
        for: 5m
        labels:
          severity: Critical
          alert_namespace: itsgenai
          alert_name: GenAI Queue Consumer Task Stalled
          alert_owner: advanalyticsapps.im@pg.com
          name_space: itsgenai
          primary_property: fingerprint
          secondary_property: startsAt
          source_system: spyglass
          uc_environment: prod
          correlation_rule: alert_name
          application_name: GenAI
          conveyor_route: universal_connector
          actionability_type: 'incident,email'
          alert_actionable: 'true'
          cost_center: 8000501288
          lob: itsgenai
          snow_assignment_group: DevOps_AdvAnalytApps
          snow_business_service: c8554ce8371c62405979a9c2b3990ef7
          snow_category: 'Business Application & Databases'
          snow_component: Alerts
          snow_configuration_item: GenAI (Artificial Intelligence) Platform
          snow_contact_type: Auto Ticket
          snow_description: 'Consumer stalled — no task runs in 10m. Celery beat scheduler or worker likely dead. Dashboard: https://grafana.spyglass.pg.com/d/genai-queue-storage-consumption'
          snow_impact: '3'
          snow_is_cbp_impacted: 'No'
          snow_incident_type: 'Operations: Application Availability'
          snow_location: ALL LOCATIONS
          snow_service_offering: 28a5002c371c62405979a9c2b3990e21
          snow_short_description: 'GenAI Queue Consumer Stalled — No Runs in 10m'
          snow_subcategory: Business Applications
          snow_urgency: '2'
          email_subject: '[GenAI Queue] CRITICAL: Consumer stalled — no task runs in 10m ({{ $labels.queue_name }})'
        annotations:
          message: >-
            No consumer task runs recorded for queue {{ $labels.queue_name }}
            ({{ $labels.cluster }}/{{ $labels.namespace }}/{{ $labels.release }})
            over the last 10m. Celery beat scheduler or worker is likely dead.

      # --- Processing Failure Rate > 10% ------------------------------------
      - alert: GenAI_QueueProcessingFailureRate_Warning
        expr: |
          sum by (cluster, namespace, release, queue_name) (
            rate(queue_messages_uploaded_total{status="failure"}[5m])
          )
          / clamp_min(
            sum by (cluster, namespace, release, queue_name) (
              rate(queue_messages_dequeued_total[5m])
            ), 0.001
          ) > 0.10
          and
          sum by (cluster, namespace, release, queue_name) (
            increase(queue_messages_dequeued_total[5m])
          ) > 20
        for: 5m
        labels:
          severity: Warning
          alert_namespace: itsgenai
          alert_name: GenAI Queue Processing Failure Rate High
          alert_owner: advanalyticsapps.im@pg.com
          name_space: itsgenai
          primary_property: fingerprint
          secondary_property: startsAt
          source_system: spyglass
          uc_environment: prod
          correlation_rule: alert_name
          email_subject: '[GenAI Queue] Processing failure rate > 10% ({{ $labels.queue_name }})'
        annotations:
          message: >-
            {{ $value | humanizePercentage }} of dequeued messages in queue
            {{ $labels.queue_name }}
            ({{ $labels.cluster }}/{{ $labels.namespace }}/{{ $labels.release }})
            failed to upload to CosmosDB over the last 5m.

      # --- Processing Duration Near Visibility Timeout (p99 > 240s = 80%) ----
      - alert: GenAI_QueueProcessingDuration_Warning
        expr: |
          histogram_quantile(0.99,
            sum by (cluster, namespace, release, queue_name, le) (
              rate(queue_message_processing_duration_seconds_bucket[5m])
            )
          ) > 240
        for: 5m
        labels:
          severity: Warning
          alert_namespace: itsgenai
          alert_name: GenAI Queue Processing Duration Near Timeout
          alert_owner: advanalyticsapps.im@pg.com
          name_space: itsgenai
          primary_property: fingerprint
          secondary_property: startsAt
          source_system: spyglass
          uc_environment: prod
          correlation_rule: alert_name
          email_subject: '[GenAI Queue] p99 processing time nearing visibility_timeout ({{ $labels.queue_name }})'
        annotations:
          message: >-
            p99 processing duration for queue {{ $labels.queue_name }}
            ({{ $labels.cluster }}/{{ $labels.namespace }}/{{ $labels.release }})
            is {{ $value | humanizeDuration }} (> 80% of the 300s visibility_timeout).
            Messages risk reappearing and being processed twice.

      # --- Processing Duration Exceeds Visibility Timeout (p99 > 285s = 95%) -
      - alert: GenAI_QueueProcessingDuration_Critical
        expr: |
          histogram_quantile(0.99,
            sum by (cluster, namespace, release, queue_name, le) (
              rate(queue_message_processing_duration_seconds_bucket[5m])
            )
          ) > 285
        for: 5m
        labels:
          severity: Critical
          alert_namespace: itsgenai
          alert_name: GenAI Queue Processing Duration Exceeds Timeout
          alert_owner: advanalyticsapps.im@pg.com
          name_space: itsgenai
          primary_property: fingerprint
          secondary_property: startsAt
          source_system: spyglass
          uc_environment: prod
          correlation_rule: alert_name
          application_name: GenAI
          conveyor_route: universal_connector
          actionability_type: 'incident,email'
          alert_actionable: 'true'
          cost_center: 8000501288
          lob: itsgenai
          snow_assignment_group: DevOps_AdvAnalytApps
          snow_business_service: c8554ce8371c62405979a9c2b3990ef7
          snow_category: 'Business Application & Databases'
          snow_component: Alerts
          snow_configuration_item: GenAI (Artificial Intelligence) Platform
          snow_contact_type: Auto Ticket
          snow_description: 'p99 processing time at visibility_timeout — message duplication likely. Dashboard: https://grafana.spyglass.pg.com/d/genai-queue-storage-consumption'
          snow_impact: '3'
          snow_is_cbp_impacted: 'No'
          snow_incident_type: 'Operations: Application Availability'
          snow_location: ALL LOCATIONS
          snow_service_offering: 28a5002c371c62405979a9c2b3990e21
          snow_short_description: 'GenAI Queue Processing Duration Exceeds Visibility Timeout'
          snow_subcategory: Business Applications
          snow_urgency: '2'
          email_subject: '[GenAI Queue] CRITICAL: p99 processing at visibility_timeout — duplication likely ({{ $labels.queue_name }})'
        annotations:
          message: >-
            p99 processing duration for queue {{ $labels.queue_name }}
            ({{ $labels.cluster }}/{{ $labels.namespace }}/{{ $labels.release }})
            is {{ $value | humanizeDuration }} (> 95% of 300s visibility_timeout).
            Messages are very likely being redelivered and processed more than once.

